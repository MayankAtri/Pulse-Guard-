NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/pulseguard
DIRECT_URL=postgresql://postgres:postgres@postgres:5432/pulseguard
REDIS_URL=redis://redis:6379
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=7
COOKIE_DOMAIN=
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
GOOGLE_CLIENT_ID=replace_google_client_id
GOOGLE_CLIENT_SECRET=replace_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
EMAIL_TRANSPORT=log
EMAIL_FROM=noreply@pulseguard.local
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
DEV_AUTH_BYPASS=false
WORKER_CONCURRENCY=5
SCHEDULER_TICK_SECONDS=5
CHECK_INTERVAL_SECONDS=60
BCRYPT_ROUNDS=12
LOG_LEVEL=warn
